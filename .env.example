# =====================================
# DATABASE CONFIGURATION
# =====================================
# Format: postgresql://username:password@host:port/database
POSTGRES_URL=postgresql://user:pass@localhost:5432/ezoterra

# =====================================
# JWT CONFIGURATION
# =====================================
# MUST be cryptographically random, minimum 32 bytes (256 bits)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# NEVER use a human-readable string. NEVER commit the real value to git.
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# =====================================
# APPLICATION ENVIRONMENT
# =====================================
NODE_ENV=production
APP_URL=https://ezoterra.vercel.app

# =====================================
# SMTP CONFIGURATION (Email Service)
# =====================================
# Required for password reset feature using OTP
# Gmail users: Use app-specific passwords, not account password
# See: https://myaccount.google.com/apppasswords

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP server port (465 for SSL, 587 for TLS)
SMTP_PORT=465

# SMTP authentication username (usually email address)
SMTP_USER=ezoterra.site@gmail.com

# SMTP authentication password (app-specific password for Gmail)
SMTP_PASS=REPLACE_WITH_APP_PASSWORD

# From email address (should match SMTP_USER or authorized sender)
SMTP_FROM=ezoterra.site@gmail.com

# =====================================
# PASSWORD RESET CONFIGURATION
# =====================================
# OTP expiration time in minutes (default: 10)
# Valid range: 1-60 minutes
RESET_OTP_EXPIRATION_MINUTES=10

# =====================================
# OPTIONAL PRODUCTION ENHANCEMENTS
# =====================================
# For rate limiting with Upstash Redis (recommended for production)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=
